# Kaspersky Threat Intelligence Portal — API Configuration
# -------------------------------------------------------
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
#
# How to obtain your API token:
#   1. Sign in at https://tip.kaspersky.com
#   2. Go to Account Settings > API tokens
#   3. Set a validity period (max 1 year) and click Request
#   4. Copy the generated token and paste it below
#
# Before using the API, you must accept the Terms and Conditions
# at https://tip.kaspersky.com (required once per account).

# Your Kaspersky TIP API token (required for API mode)
KASPERSKY_TIP_TOKEN=your_api_token_here

# Base URL for the Kaspersky TIP Data Feeds API (do not change unless instructed)
KASPERSKY_TIP_BASE_URL=https://tip.kaspersky.com/api/feeds/

# Feed endpoint name for the IP Reputation feed.
# The exact name may vary — check the OpenAPI spec at:
# https://tip.kaspersky.com/Help/api/?specId=tip-feeds-api
# Known candidates: ip_reputation, IP_Reputation, dangerous_ips
KASPERSKY_TIP_FEED_ENDPOINT=ip_reputation

# Maximum number of records to download per request.
# Set to 0 for no limit (full feed). Check your license for allowed values.
KASPERSKY_TIP_LIMIT=0
